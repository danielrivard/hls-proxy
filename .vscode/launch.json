{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: run_flask.py",
      "type": "debugpy",
      "request": "launch",
      "program": "run_flask.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: run_falcon.py",
      "type": "debugpy",
      "request": "launch",
      "program": "run_falcon.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: Flask",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--no-debugger",
        // "--no-reload"
      ],
      "jinja": true,
      "autoStartBrowser": false
    }
  ]
}